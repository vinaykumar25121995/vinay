      <column caption=' Age Group' datatype='string' name='[Calculation_159877837182476290]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Age] &lt; 25 THEN &quot;Young&quot;&#13;&#10;ELSEIF [Age] &lt; 30 THEN &quot;Prime&quot;&#13;&#10;ELSE &quot;Veteran&quot;&#13;&#10;END' />
      </column>
      <column caption='●Market Value as Numeric' datatype='string' name='[Calculation_159877837185261571]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF CONTAINS(STR([Value]), &quot;M&quot;) THEN&#13;&#10;    REPLACE(REPLACE(STR([Value]), &quot;€&quot;, &quot;&quot;), &quot;M&quot;, &quot; Million&quot;)&#13;&#10;ELSEIF CONTAINS(STR([Value]), &quot;K&quot;) THEN&#13;&#10;    REPLACE(REPLACE(STR([Value]), &quot;€&quot;, &quot;&quot;), &quot;K&quot;, &quot; Thousand&quot;)&#13;&#10;ELSE&#13;&#10;    REPLACE(STR([Value]), &quot;€&quot;, &quot;&quot;)&#13;&#10;END' />
